# Database
DATABASE_URL=postgresql://sefdp:sefdp_dev@localhost:5432/sefdp
POSTGRES_DB=sefdp
POSTGRES_USER=sefdp
POSTGRES_PASSWORD=sefdp_dev

# Redis
REDIS_URL=redis://:redis_dev@localhost:6379
REDIS_PASSWORD=redis_dev

# JWT
JWT_PRIVATE_KEY=generate-rsa-private-key
JWT_PUBLIC_KEY=generate-rsa-public-key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=sefdp_minio
MINIO_ROOT_PASSWORD=sefdp_minio_dev
MINIO_BUCKET=sefdp-documents

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@sefdp.org

# App
NODE_ENV=development
API_PORT=3001
API_HOST=0.0.0.0
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000

# Encryption
ENCRYPTION_KEY=generate-32-byte-hex-key

# Webhooks (HMAC-SHA256 signature verification)
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=generate-32-byte-hex-key

# External APIs
REA_API_URL=https://api.rea.gov.ng
REA_API_KEY=

# Rate Limiting
RATE_LIMIT_PUBLIC=20
RATE_LIMIT_AUTH=5
RATE_LIMIT_AUTHENTICATED=200
RATE_LIMIT_UPLOAD=10
